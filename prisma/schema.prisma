generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]  // ← NEW: required for Neon adapter
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")           // pooled — used at runtime
  directUrl = env("DATABASE_URL_UNPOOLED")  // direct — used by CLI only
}

model User {
  id             String     @id @default(cuid())
  firstName      String
  lastName       String
  email          String?    @unique
  isEmailVerified Boolean   @default(true)
  emailVerifiedAt DateTime?
  phone          String?    @unique
  passwordHash   String
  age            Int
  gender         String
  birthday       DateTime
  role           String     @default("MEMBER")
  isActive       Boolean    @default(true)
  profilePhoto   String?
  cellGroupId    String?
  cellGroup      CellGroup? @relation(fields: [cellGroupId], references: [id])
  sessions       Session[]
  attendance     Attendance[]
  posts          Post[]
  likes          Like[]
  comments       Comment[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens PasswordResetToken[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([role])
  @@index([cellGroupId])
  @@index([isActive])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Session {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime

  @@index([userId])
}

model CellGroup {
  id          String       @id @default(cuid())
  name        String
  leaderId    String
  meetingDay  String?
  meetingTime String?
  barangay    String?
  isActive    Boolean      @default(true)
  members     User[]
  attendance  Attendance[]
  posts       Post[]
  createdAt   DateTime     @default(now())

  @@index([isActive])
  @@index([leaderId])
}

model Attendance {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  cellGroupId String?
  cellGroup   CellGroup? @relation(fields: [cellGroupId], references: [id])
  type        String
  status      String
  date        DateTime
  markedById  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([userId, type, date])
  @@index([userId, date])
  @@index([cellGroupId, date])
  @@index([date, type])
}

model Sermon {
  id          String   @id @default(cuid())
  title       String
  speaker     String
  series      String?
  videoUrl    String?
  audioUrl    String?
  notes       String?
  thumbnail   String?
  date        DateTime
  tags        String
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([series])
  @@index([speaker])
  @@index([isPublished])
}

model Event {
  id          String    @id @default(cuid())
  title       String
  description String
  location    String
  startDate   DateTime
  endDate     DateTime?
  imageUrl    String?
  isPublished Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([startDate])
  @@index([isPublished])
}

model Ministry {
  id          String   @id @default(cuid())
  name        String
  description String
  imageUrl    String?
  leader      String
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([isActive])
}

model BlogPost {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  content     String
  excerpt     String?
  category    String
  imageUrl    String?
  authorId    String
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([slug])
  @@index([isPublished, publishedAt])
}

model Post {
  id          String     @id @default(cuid())
  authorId    String
  author      User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content     String
  bibleVerse  String?
  bibleText   String?
  scope       String     @default("PUBLIC")
  isApproved  Boolean    @default(false)
  cellGroupId String?
  cellGroup   CellGroup? @relation(fields: [cellGroupId], references: [id])
  likes       Like[]
  comments    Comment[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([isApproved, scope, createdAt])
  @@index([cellGroupId, isApproved])
  @@index([authorId])
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@index([postId, createdAt])
}

model PrayerRequest {
  id          String   @id @default(cuid())
  name        String
  email       String?
  request     String
  isPrivate   Boolean  @default(false)
  isAnswered  Boolean  @default(false)
  submittedAt DateTime @default(now())

  @@index([submittedAt])
  @@index([isAnswered])
}

model GivingRecord {
  id              String   @id @default(cuid())
  stripePaymentId String   @unique
  amount          Int
  currency        String   @default("PHP")
  category        String
  giverName       String?
  giverEmail      String?
  status          String
  createdAt       DateTime @default(now())

  @@index([createdAt])
  @@index([status])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
